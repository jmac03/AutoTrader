# ============================================================
# .env.example - Example Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# The .env file is listed in .gitignore and will NOT be committed.
#
# Get your Alpaca API keys at: https://app.alpaca.markets/
#   - Paper trading keys are free and safe for development.
#   - Live trading keys require a funded brokerage account.
#
# NEVER share your secret key or commit the .env file to Git.
# ============================================================

# Alpaca API key ID (starts with "PK" for paper trading)
ALPACA_API_KEY=your_api_key_here

# Alpaca secret key
ALPACA_SECRET_KEY=your_secret_key_here

# Base URL:
#   Paper trading: https://paper-api.alpaca.markets
#   Live trading:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
